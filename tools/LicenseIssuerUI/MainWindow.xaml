<Window x:Class="LicenseIssuerUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MediaTrans 激活码签发工具"
        Width="620" Height="520"
        MinWidth="560" MinHeight="480"
        WindowStartupLocation="CenterScreen"
        Background="#1A1D2E"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- 颜色常量 -->
        <SolidColorBrush x:Key="BgDark"    Color="#1A1D2E"/>
        <SolidColorBrush x:Key="BgSurface" Color="#252840"/>
        <SolidColorBrush x:Key="BgInput"   Color="#1E2133"/>
        <SolidColorBrush x:Key="Accent"    Color="#4A9EFF"/>
        <SolidColorBrush x:Key="AccentHover" Color="#6EB5FF"/>
        <SolidColorBrush x:Key="Success"   Color="#4CAF82"/>
        <SolidColorBrush x:Key="Danger"    Color="#E05050"/>
        <SolidColorBrush x:Key="FgPrimary"   Color="#E8EAF6"/>
        <SolidColorBrush x:Key="FgSecondary" Color="#9E9EB8"/>
        <SolidColorBrush x:Key="Border"    Color="#3A3D5C"/>

        <!-- Label 样式 -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource FgSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <!-- 输入框样式 -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BgInput}"/>
            <Setter Property="Foreground" Value="{StaticResource FgPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="CaretBrush" Value="{StaticResource Accent}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 主操作按钮 -->
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#3A8EEF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Background" Value="#2A3A5A"/>
                                <Setter Property="Foreground" Value="{StaticResource FgSecondary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 次要按钮 -->
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource Accent}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1A2A4A"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#142038"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>   <!-- 标题栏 -->
            <RowDefinition Height="*"/>    <!-- 内容 -->
            <RowDefinition Height="36"/>   <!-- 状态栏 -->
        </Grid.RowDefinitions>

        <!-- ===== 标题栏 ===== -->
        <Border Grid.Row="0" Background="#20233A">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0">
                <TextBlock Text="🔑" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="MediaTrans 激活码签发工具"
                               Foreground="{StaticResource FgPrimary}"
                               FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock Text="仅供开发者本地使用，请妥善保管私钥文件"
                               Foreground="{StaticResource FgSecondary}"
                               FontSize="11"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ===== 主内容 ===== -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,20">

                <!-- 私钥文件 -->
                <Border Background="{StaticResource BgSurface}" CornerRadius="6"
                        Padding="16,14" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="① 私钥文件" Style="{StaticResource FieldLabel}"
                                   FontWeight="SemiBold" Foreground="{StaticResource Accent}"/>
                        <TextBlock Text="选择 private_key.pem 文件（由 KeyGenerator 工具生成）"
                                   Style="{StaticResource FieldLabel}" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtKeyPath"
                                     Grid.Column="0"
                                     Style="{StaticResource DarkTextBox}"
                                     IsReadOnly="True"
                                     Text="{Binding ElementName=TxtKeyPath, Path=Tag, Mode=OneWay}"
                                     Tag=""
                                     Margin="0,0,8,0"/>
                            <Button Grid.Column="1" Content="浏览..."
                                    Style="{StaticResource GhostButton}"
                                    Padding="14,6"
                                    Click="BtnBrowseKey_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 机器码 -->
                <Border Background="{StaticResource BgSurface}" CornerRadius="6"
                        Padding="16,14" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="② 机器码" Style="{StaticResource FieldLabel}"
                                   FontWeight="SemiBold" Foreground="{StaticResource Accent}"/>
                        <TextBlock Text="粘贴用户从软件「许可证管理」窗口提供的 64 位机器码"
                                   Style="{StaticResource FieldLabel}" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtMachineCode"
                                     Grid.Column="0"
                                     Style="{StaticResource DarkTextBox}"
                                     FontFamily="Consolas"
                                     Margin="0,0,8,0"
                                     MaxLength="64"
                                     TextChanged="TxtInput_TextChanged"/>
                            <Button Grid.Column="1" Content="粘贴"
                                    Style="{StaticResource GhostButton}"
                                    Padding="14,6"
                                    Click="BtnPasteMachineCode_Click"/>
                        </Grid>
                        <TextBlock x:Name="TxtMachineCodeHint"
                                   Foreground="#E09040" FontSize="11"
                                   Margin="0,5,0,0" Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                <!-- 版本号 -->
                <Border Background="{StaticResource BgSurface}" CornerRadius="6"
                        Padding="16,14" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="③ 授权版本号" Style="{StaticResource FieldLabel}"
                                   FontWeight="SemiBold" Foreground="{StaticResource Accent}"/>
                        <TextBlock Text="用于标识授权版本，通常填 1.0"
                                   Style="{StaticResource FieldLabel}" Margin="0,0,0,8"/>
                        <TextBox x:Name="TxtVersion"
                                 Style="{StaticResource DarkTextBox}"
                                 Text="1.0"
                                 Width="120"
                                 HorizontalAlignment="Left"
                                 TextChanged="TxtInput_TextChanged"/>
                    </StackPanel>
                </Border>

                <!-- 生成按钮 -->
                <Button x:Name="BtnGenerate"
                        Content="生成激活码"
                        Style="{StaticResource AccentButton}"
                        Height="40" Padding="0,0"
                        IsEnabled="False"
                        Click="BtnGenerate_Click"
                        Margin="0,0,0,16"/>

                <!-- 激活码输出 -->
                <Border x:Name="OutputSection"
                        Background="{StaticResource BgSurface}" CornerRadius="6"
                        Padding="16,14" Visibility="Collapsed">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="✅ 激活码已生成"
                                       Foreground="{StaticResource Success}"
                                       FontSize="13" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="复制激活码"
                                    Style="{StaticResource GhostButton}"
                                    Padding="12,5"
                                    Click="BtnCopyLicense_Click"/>
                        </Grid>
                        <TextBox x:Name="TxtLicenseCode"
                                 Style="{StaticResource DarkTextBox}"
                                 FontFamily="Consolas"
                                 FontSize="11"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="False"
                                 Height="80"
                                 VerticalScrollBarVisibility="Auto"/>
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="{StaticResource FgSecondary}"
                                   FontSize="11">
                            <Run Text="请将以上激活码完整发送给用户，用户在软件「许可证管理」窗口粘贴后点击「激活」即可。"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ===== 状态栏 ===== -->
        <Border Grid.Row="2" Background="#141625"
                BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
            <TextBlock x:Name="TxtStatus"
                       Foreground="{StaticResource FgSecondary}"
                       FontSize="11"
                       VerticalAlignment="Center"
                       Margin="16,0"
                       Text="就绪 — 请先选择私钥文件"/>
        </Border>
    </Grid>
</Window>
