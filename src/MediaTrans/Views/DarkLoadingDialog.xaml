<Window x:Class="MediaTrans.Views.DarkLoadingDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="请稍候" SizeToContent="WidthAndHeight"
        MinWidth="300" MaxWidth="420"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True">

    <Border Background="{DynamicResource BgDarkBrush}"
            BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1"
            CornerRadius="6" Margin="8" Padding="24,20">
        <Border.Effect>
            <DropShadowEffect Color="#FF000000" Opacity="0.6" BlurRadius="16" ShadowDepth="4"/>
        </Border.Effect>
        <StackPanel>
            <!-- 旋转动画圆环 -->
            <Grid Width="36" Height="36" HorizontalAlignment="Center" Margin="0,0,0,16">
                <Ellipse Width="36" Height="36" StrokeThickness="3"
                         Stroke="{DynamicResource BgHighlightBrush}"/>
                <Path x:Name="SpinnerArc"
                      Stroke="{DynamicResource AccentPrimaryBrush}"
                      StrokeThickness="3" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      RenderTransformOrigin="0.5,0.5">
                    <Path.Data>
                        <PathGeometry>
                            <PathFigure StartPoint="18,0" IsClosed="False">
                                <ArcSegment Point="36,18" Size="18,18"
                                            SweepDirection="Clockwise" IsLargeArc="False"/>
                            </PathFigure>
                        </PathGeometry>
                    </Path.Data>
                    <Path.RenderTransform>
                        <RotateTransform x:Name="SpinnerRotation" Angle="0"/>
                    </Path.RenderTransform>
                    <Path.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="SpinnerRotation"
                                                     Storyboard.TargetProperty="Angle"
                                                     From="0" To="360"
                                                     Duration="0:0:1"
                                                     RepeatBehavior="Forever"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Path.Triggers>
                </Path>
            </Grid>

            <!-- 消息文本 -->
            <TextBlock x:Name="MessageText"
                       Text="正在处理，请稍候..."
                       Foreground="{DynamicResource FgSecondaryBrush}"
                       FontSize="13" TextWrapping="Wrap"
                       TextAlignment="Center" LineHeight="20"
                       HorizontalAlignment="Center"/>

            <!-- 进度条（可选） -->
            <ProgressBar x:Name="ProgressBarCtrl"
                         Margin="0,12,0,0" Height="6"
                         Minimum="0" Maximum="100" Value="0"
                         Visibility="Collapsed"/>
        </StackPanel>
    </Border>
</Window>
