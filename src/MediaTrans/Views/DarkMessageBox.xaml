<Window x:Class="MediaTrans.Views.DarkMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="提示" SizeToContent="WidthAndHeight"
        MinWidth="340" MaxWidth="500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Border Background="{DynamicResource BgDarkBrush}"
            BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1"
            CornerRadius="6" Margin="8">
        <Border.Effect>
            <DropShadowEffect Color="#FF000000" Opacity="0.5" BlurRadius="12" ShadowDepth="3"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Border Grid.Row="0" Background="{DynamicResource BgLightBrush}"
                    CornerRadius="6,6,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="IconText" Grid.Column="0"
                               FontSize="14" VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <TextBlock x:Name="TitleText" Grid.Column="1"
                               Foreground="{DynamicResource FgPrimaryBrush}"
                               FontSize="13" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- 内容区 -->
            <StackPanel Grid.Row="1" Margin="20,16,20,20">
                <TextBlock x:Name="MessageText"
                           Foreground="{DynamicResource FgSecondaryBrush}"
                           FontSize="13" TextWrapping="Wrap"
                           LineHeight="20"/>
            </StackPanel>

            <!-- 按钮区 -->
            <Border Grid.Row="2" Background="{DynamicResource BgMediumBrush}"
                    CornerRadius="0,0,6,6" Padding="16,10">
                <StackPanel x:Name="ButtonPanel" Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <!-- 按钮在代码中动态添加 -->
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
