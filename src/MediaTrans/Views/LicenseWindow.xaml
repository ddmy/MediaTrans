<Window x:Class="MediaTrans.Views.LicenseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="许可证管理" Height="380" Width="500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Border Background="{DynamicResource BgDarkBrush}" 
            BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1"
            CornerRadius="4" Margin="5">
        <Grid>
            <Grid.RowDefinitions>
                <!-- 标题栏 -->
                <RowDefinition Height="32"/>
                <!-- 内容区 -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Grid Grid.Row="0" Background="{DynamicResource BgLightBrush}" 
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                    <TextBlock Text="🔑" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="许可证管理" Foreground="{DynamicResource FgSecondaryBrush}" 
                               FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="1" Click="BtnClose_Click"
                        Style="{StaticResource WindowCloseButton}"
                        ToolTip="关闭">
                    <Path Data="M4,4 L12,12 M12,4 L4,12" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1" Width="16" Height="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Button>
            </Grid>

            <!-- 内容区 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20,15">

                    <!-- 授权状态区域 -->
                    <Border Background="{DynamicResource BgMediumBrush}" 
                            CornerRadius="4" Padding="12,10" Margin="0,0,0,15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="授权状态：" 
                                       Foreground="{DynamicResource FgSecondaryBrush}" 
                                       FontSize="13" VerticalAlignment="Center"/>
                            <!-- 已激活 -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal" 
                                        Visibility="{Binding IsActivated, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="✓ 专业版已激活" FontSize="13" VerticalAlignment="Center">
                                    <TextBlock.Foreground>
                                        <SolidColorBrush Color="{StaticResource AccentSuccess}"/>
                                    </TextBlock.Foreground>
                                </TextBlock>
                            </StackPanel>
                            <!-- 未激活 -->
                            <TextBlock Grid.Column="1" Text="免费版" FontSize="13" VerticalAlignment="Center"
                                       Visibility="{Binding IsActivated, Converter={StaticResource BoolToVisibilityInverse}}">
                                <TextBlock.Foreground>
                                    <SolidColorBrush Color="{StaticResource AccentDanger}"/>
                                </TextBlock.Foreground>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- 机器码区域 -->
                    <TextBlock Text="本机机器码" Foreground="{DynamicResource FgSecondaryBrush}" 
                               FontSize="12" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding MachineCode, Mode=OneWay}" 
                                 IsReadOnly="True" FontSize="11" FontFamily="Consolas"
                                 Background="{DynamicResource BgMediumBrush}"
                                 Foreground="{DynamicResource FgPrimaryBrush}"
                                 BorderBrush="{DynamicResource BorderDefaultBrush}"
                                 Padding="6,4"/>
                        <Button Grid.Column="1" Content="复制" 
                                Style="{StaticResource DarkButton}"
                                Command="{Binding CopyMachineCodeCommand}"
                                Padding="10,4" Margin="6,0,0,0" FontSize="12"/>
                    </Grid>

                    <!-- 免费版限制说明（未激活时显示） -->
                    <Border Visibility="{Binding IsActivated, Converter={StaticResource BoolToVisibilityInverse}}"
                            Background="#30FFE050" BorderBrush="#60FFE050" BorderThickness="1"
                            CornerRadius="4" Padding="12,10" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="⚠ 免费版限制" FontSize="13" FontWeight="Bold" Margin="0,0,0,6">
                                <TextBlock.Foreground>
                                    <SolidColorBrush Color="#FFE0A050"/>
                                </TextBlock.Foreground>
                            </TextBlock>
                            <TextBlock Foreground="{DynamicResource FgSecondaryBrush}" FontSize="12" TextWrapping="Wrap" LineHeight="22">
                                <Run Text="· 导出时长上限 60 秒（超出部分自动截断）"/><LineBreak/>
                                <Run Text="· 视频导出自动添加水印"/><LineBreak/>
                                <Run Text="· 不支持无损格式导出（FLAC / WAV）"/>
                            </TextBlock>
                            <TextBlock Text="激活专业版即可解除以上全部限制。" 
                                       Foreground="{DynamicResource FgMutedBrush}" 
                                       FontSize="11" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- 激活码输入区域（未激活时显示） -->
                    <StackPanel Visibility="{Binding IsActivated, Converter={StaticResource BoolToVisibilityInverse}}">
                        <TextBlock Text="输入激活码" Foreground="{DynamicResource FgSecondaryBrush}" 
                                   FontSize="12" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding LicenseCode, UpdateSourceTrigger=PropertyChanged}" 
                                 FontSize="12" FontFamily="Consolas"
                                 Background="{DynamicResource BgMediumBrush}"
                                 Foreground="{DynamicResource FgPrimaryBrush}"
                                 BorderBrush="{DynamicResource BorderDefaultBrush}"
                                 Padding="6,4" Margin="0,0,0,10"
                                 AcceptsReturn="False" TextWrapping="Wrap"
                                 Height="50"/>
                        <Button Content="激活" Style="{StaticResource AccentButton}"
                                Command="{Binding ActivateCommand}"
                                HorizontalAlignment="Right" Padding="20,5" FontSize="13"/>
                    </StackPanel>

                    <!-- 状态消息 -->
                    <TextBlock Text="{Binding StatusMessage}" 
                               Foreground="{DynamicResource FgMutedBrush}" 
                               FontSize="12" Margin="0,10,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
