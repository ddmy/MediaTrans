<Window x:Class="MediaTrans.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MediaTrans.ViewModels"
        Title="{Binding Title}" Height="600" Width="900"
        MinHeight="400" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <!-- 外层边框提供阴影和圆角 -->
    <Border Background="{DynamicResource BgDarkBrush}" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1"
            Margin="5">
        <Grid>
            <Grid.RowDefinitions>
                <!-- 标题栏 -->
                <RowDefinition Height="32"/>
                <!-- 内容区 -->
                <RowDefinition Height="*"/>
                <!-- 状态栏 -->
                <RowDefinition Height="24"/>
            </Grid.RowDefinitions>

            <!-- 自定义标题栏 -->
            <Grid Grid.Row="0" Background="{DynamicResource BgLightBrush}" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 应用图标和标题 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                    <TextBlock Text="🎬" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding Title}" Foreground="{DynamicResource FgSecondaryBrush}" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 窗口控制按钮 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <!-- 最小化按钮 -->
                    <Button x:Name="BtnMinimize" Click="BtnMinimize_Click"
                            Style="{StaticResource WindowControlButton}"
                            FontFamily="Segoe MDL2 Assets" Content="&#xE921;"
                            ToolTip="最小化"/>
                    <!-- 最大化/还原按钮 -->
                    <Button x:Name="BtnMaximize" Click="BtnMaximize_Click"
                            Style="{StaticResource WindowControlButton}"
                            FontFamily="Segoe MDL2 Assets" Content="&#xE922;"
                            ToolTip="最大化"/>
                    <!-- 关闭按钮 -->
                    <Button x:Name="BtnClose" Click="BtnClose_Click"
                            Style="{StaticResource WindowCloseButton}"
                            FontFamily="Segoe MDL2 Assets" Content="&#xE8BB;"
                            ToolTip="关闭"/>
                </StackPanel>
            </Grid>

            <!-- 主内容区 -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <!-- 激活提示横幅（未激活时显示） -->
                    <RowDefinition Height="Auto"/>
                    <!-- 工具栏 -->
                    <RowDefinition Height="36"/>
                    <!-- 左侧文件列表 + 中央预览/编辑区 -->
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 激活提示横幅 -->
                <Border Grid.Row="0" Background="#FFE05050" Padding="6,4"
                        Visibility="{Binding IsLicensed, Converter={StaticResource BoolToVisibilityInverse}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="当前为免费版，部分功能受限。激活专业版解锁全部功能。" 
                                   Foreground="White" FontSize="12" VerticalAlignment="Center" Margin="8,0"/>
                        <Button Grid.Column="1" Content="立即激活" 
                                Style="{StaticResource DarkButton}"
                                Command="{Binding OpenLicenseCommand}"
                                Padding="10,2" Margin="0,0,4,0" FontSize="11"/>
                    </Grid>
                </Border>

                <!-- 顶部工具栏 -->
                <Border Grid.Row="1" Background="{DynamicResource BgMediumBrush}"
                        BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                        <Button Content="导入文件" Style="{StaticResource DarkButton}" 
                                Command="{Binding ImportFilesCommand}"
                                Padding="10,3" Margin="0,0,4,0" FontSize="12"/>
                        <Button Content="开始转换" Style="{StaticResource AccentButton}" 
                            Command="{Binding StartConversionCommand}"
                                Padding="10,3" Margin="0,0,4,0" FontSize="12"/>
                        <Button Content="停止" Style="{StaticResource DarkButton}" 
                            Command="{Binding StopConversionCommand}"
                                Padding="10,3" Margin="0,0,16,0" FontSize="12"/>
                        <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" 
                                   Margin="0,4" Background="{DynamicResource BorderDefaultBrush}"/>
                        <Button Content="许可证" Style="{StaticResource DarkButton}" 
                                Command="{Binding OpenLicenseCommand}"
                                Padding="10,3" Margin="16,0,0,0" FontSize="12" ToolTip="许可证管理"/>
                    </StackPanel>
                </Border>

                <!-- 左侧文件列表 + 中央预览区 -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <!-- 左侧文件列表面板 -->
                        <ColumnDefinition Width="260" MinWidth="180" MaxWidth="500"/>
                        <!-- GridSplitter -->
                        <ColumnDefinition Width="4"/>
                        <!-- 中央预览/编辑区 -->
                        <ColumnDefinition Width="*" MinWidth="300"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左侧文件列表面板 -->
                    <Border Grid.Column="0" Background="{DynamicResource BgDarkBrush}"
                            BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,0,1,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <!-- 面板标题 -->
                            <Border Grid.Row="0" Background="{DynamicResource BgLightBrush}">
                                <TextBlock Text="文件列表" Foreground="{DynamicResource FgSecondaryBrush}" 
                                           FontSize="12" VerticalAlignment="Center" Margin="10,0"/>
                            </Border>
                            <!-- 文件列表区域 -->
                            <ListBox Grid.Row="1" Style="{StaticResource DarkListBox}" 
                                     BorderThickness="0"
                                     Background="{DynamicResource BgDarkBrush}"
                                     ItemsSource="{Binding Files}"
                                     SelectedItem="{Binding SelectedFile}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="4,3">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <!-- 文件名 -->
                                            <TextBlock Grid.Row="0" Text="{Binding FileName}" 
                                                       Foreground="{DynamicResource FgPrimaryBrush}" 
                                                       FontSize="12" TextTrimming="CharacterEllipsis"/>
                                            <!-- 元信息摘要 -->
                                            <TextBlock Grid.Row="1" FontSize="10"
                                                       Foreground="{DynamicResource FgMutedBrush}" Margin="0,2,0,0">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0}  {1}">
                                                        <Binding Path="DurationText" Mode="OneWay"/>
                                                        <Binding Path="FileSizeText" Mode="OneWay"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <!-- 可拖拽分隔条 -->
                    <GridSplitter Grid.Column="1" Width="4" 
                                  HorizontalAlignment="Stretch"
                                  Background="{DynamicResource BgHighlightBrush}"
                                  Cursor="SizeWE"/>

                    <!-- 中央预览/编辑区 -->
                    <Border Grid.Column="2" Background="{DynamicResource BgDarkestBrush}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="36"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- 模式选择标签栏 -->
                            <Border Grid.Row="0" Background="{DynamicResource BgLightBrush}"
                                    BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,0,0,1">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                                    <Button Content="转换" Style="{StaticResource DarkButton}"
                                            Command="{Binding SwitchToConvertCommand}"
                                            Padding="14,3" Margin="0,0,4,0" FontSize="12"/>
                                    <Button Content="编辑器" Style="{StaticResource DarkButton}"
                                            Command="{Binding SwitchToEditorCommand}"
                                            Padding="14,3" FontSize="12"/>
                                </StackPanel>
                            </Border>

                            <!-- 转换模式面板 -->
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                          Visibility="{Binding IsEditorMode, Converter={StaticResource BoolToVisibilityInverse}}">
                                <StackPanel Margin="16">

                                    <!-- 未选文件时的占位提示 -->
                                    <TextBlock Text="请导入音视频文件"
                                               Foreground="{DynamicResource FgMutedBrush}" FontSize="14"
                                               HorizontalAlignment="Center" Margin="0,40,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedFile}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!-- 文件信息与设置区（选中文件后可见） -->
                                    <StackPanel>
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedFile}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>

                                        <!-- 文件信息 -->
                                        <TextBlock Text="文件信息" Foreground="{DynamicResource FgPrimaryBrush}"
                                                   FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <TextBlock Foreground="{DynamicResource FgSecondaryBrush}" FontSize="12"
                                                   Margin="0,2,0,0" TextTrimming="CharacterEllipsis">
                                            <Run Text="名称："/>
                                            <Run Text="{Binding SelectedFile.FileName, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock Foreground="{DynamicResource FgSecondaryBrush}" FontSize="12" Margin="0,2,0,0">
                                            <Run Text="时长："/>
                                            <Run Text="{Binding SelectedFile.DurationText, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock Foreground="{DynamicResource FgSecondaryBrush}" FontSize="12" Margin="0,2,0,0">
                                            <Run Text="格式："/>
                                            <Run Text="{Binding SelectedFile.Format, Mode=OneWay}"/>
                                        </TextBlock>

                                        <!-- 转换设置 -->
                                        <TextBlock Text="转换设置" Foreground="{DynamicResource FgPrimaryBrush}"
                                                   FontSize="13" FontWeight="SemiBold" Margin="0,16,0,8"/>

                                        <!-- 输出格式 -->
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="输出格式："
                                                       Foreground="{DynamicResource FgSecondaryBrush}"
                                                       FontSize="12" VerticalAlignment="Center"/>
                                            <ComboBox Grid.Column="1"
                                                      Style="{StaticResource DarkComboBox}"
                                                      ItemsSource="{Binding SettingsVm.OutputFormats}"
                                                      SelectedItem="{Binding SettingsVm.SelectedFormat}"
                                                      FontSize="12"/>
                                        </Grid>

                                        <!-- 预设 -->
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="预设："
                                                       Foreground="{DynamicResource FgSecondaryBrush}"
                                                       FontSize="12" VerticalAlignment="Center"/>
                                            <ComboBox Grid.Column="1"
                                                      Style="{StaticResource DarkComboBox}"
                                                      ItemsSource="{Binding SettingsVm.Presets}"
                                                      SelectedItem="{Binding SettingsVm.SelectedPreset}"
                                                      DisplayMemberPath="Name"
                                                      FontSize="12"/>
                                        </Grid>

                                        <!-- 提取按钮 -->
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <Button Content="提取音频" Style="{StaticResource DarkButton}"
                                                    Command="{Binding ExtractAudioCommand}"
                                                    Padding="10,4" Margin="0,0,8,0" FontSize="12"/>
                                            <Button Content="提取视频" Style="{StaticResource DarkButton}"
                                                    Command="{Binding ExtractVideoCommand}"
                                                    Padding="10,4" FontSize="12"/>
                                        </StackPanel>

                                        <!-- 校验消息 -->
                                        <TextBlock Text="{Binding SettingsVm.ValidationMessage}"
                                                   Foreground="#FFE05050" FontSize="11" Margin="0,6,0,0"
                                                   TextWrapping="Wrap"/>

                                        <!-- 进度区（转换中时可见） -->
                                        <Border Margin="0,14,0,0" Padding="12"
                                                Background="{DynamicResource BgMediumBrush}"
                                                BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1"
                                                Visibility="{Binding ProgressVm.ShowProgressPanel, Converter={StaticResource BoolToVisibility}}">
                                            <StackPanel>
                                                <ProgressBar Style="{StaticResource DarkProgressBar}"
                                                             Value="{Binding ProgressVm.ProgressPercentage, Mode=OneWay}"
                                                             Minimum="0" Maximum="100" Height="8"/>
                                                <Grid Margin="0,6,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding ProgressVm.ProgressText, Mode=OneWay}"
                                                               Foreground="{DynamicResource FgSecondaryBrush}" FontSize="12"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding ProgressVm.RemainingTimeText, Mode=OneWay}"
                                                               Foreground="{DynamicResource FgMutedBrush}" FontSize="11"/>
                                                </Grid>
                                                <TextBlock Text="日志" Foreground="{DynamicResource FgSecondaryBrush}"
                                                           FontSize="11" Margin="0,8,0,4"/>
                                                <ListBox Style="{StaticResource DarkListBox}"
                                                         ItemsSource="{Binding ProgressVm.LogEntries}"
                                                         MaxHeight="80" FontSize="10"
                                                         BorderThickness="0"
                                                         ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- 编辑器模式面板 -->
                            <Grid Grid.Row="1"
                                  Visibility="{Binding IsEditorMode, Converter={StaticResource BoolToVisibility}}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel Margin="16">
                                        <TextBlock Text="波形编辑器" Foreground="{DynamicResource FgPrimaryBrush}"
                                                   FontSize="13" FontWeight="SemiBold" Margin="0,0,0,12"/>

                                        <!-- 波形画布占位 -->
                                        <Border Height="120" Background="{DynamicResource BgMediumBrush}"
                                                BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1"
                                                Margin="0,0,0,12">
                                            <TextBlock Text="波形编辑器将在下一版本提供完整渲染"
                                                       Foreground="{DynamicResource FgMutedBrush}" FontSize="12"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- 播放控件占位 -->
                                        <TextBlock Text="播放控件" Foreground="{DynamicResource FgSecondaryBrush}"
                                                   FontSize="12" Margin="0,0,0,6"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                            <Button Content="▶ 播放" Style="{StaticResource DarkButton}"
                                                    Padding="10,4" Margin="0,0,8,0" FontSize="12" IsEnabled="False"/>
                                            <Button Content="⏹ 停止" Style="{StaticResource DarkButton}"
                                                    Padding="10,4" FontSize="12" IsEnabled="False"/>
                                        </StackPanel>

                                        <!-- 选区信息 -->
                                        <TextBlock Text="选区信息" Foreground="{DynamicResource FgSecondaryBrush}"
                                                   FontSize="12" Margin="0,0,0,6"/>
                                        <Grid Margin="0,0,0,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="起点："
                                                       Foreground="{DynamicResource FgMutedBrush}" FontSize="11"/>
                                            <TextBlock Grid.Column="1" Text="--:--"
                                                       Foreground="{DynamicResource FgSecondaryBrush}" FontSize="11"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="终点："
                                                       Foreground="{DynamicResource FgMutedBrush}" FontSize="11"/>
                                            <TextBlock Grid.Column="1" Text="--:--"
                                                       Foreground="{DynamicResource FgSecondaryBrush}" FontSize="11"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="时长："
                                                       Foreground="{DynamicResource FgMutedBrush}" FontSize="11"/>
                                            <TextBlock Grid.Column="1" Text="--:--"
                                                       Foreground="{DynamicResource FgSecondaryBrush}" FontSize="11"/>
                                        </Grid>

                                        <!-- 增益调节 -->
                                        <TextBlock Text="增益调节" Foreground="{DynamicResource FgSecondaryBrush}"
                                                   FontSize="12" Margin="0,0,0,6"/>
                                        <Slider Style="{StaticResource DarkSlider}"
                                                Minimum="-20" Maximum="20" Value="0"
                                                TickFrequency="5" IsSnapToTickEnabled="True"
                                                IsEnabled="False"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- 状态栏 -->
            <Border Grid.Row="2" Background="{DynamicResource BgMediumBrush}">
                <TextBlock Text="{Binding StatusText}" 
                           Foreground="{DynamicResource FgMutedBrush}" FontSize="11"
                           VerticalAlignment="Center" Margin="10,0,0,0"/>
            </Border>

            <!-- 缩放把手（8个方向） -->
            <!-- 左边缘 -->
            <Thumb Grid.Row="0" Grid.RowSpan="3" Width="5" HorizontalAlignment="Left" 
                   Cursor="SizeWE" Opacity="0" DragDelta="ResizeThumb_DragDelta" Tag="Left"/>
            <!-- 右边缘 -->
            <Thumb Grid.Row="0" Grid.RowSpan="3" Width="5" HorizontalAlignment="Right" 
                   Cursor="SizeWE" Opacity="0" DragDelta="ResizeThumb_DragDelta" Tag="Right"/>
            <!-- 上边缘 -->
            <Thumb Grid.Row="0" Height="5" VerticalAlignment="Top" 
                   Cursor="SizeNS" Opacity="0" DragDelta="ResizeThumb_DragDelta" Tag="Top"/>
            <!-- 下边缘 -->
            <Thumb Grid.Row="2" Height="5" VerticalAlignment="Bottom" 
                   Cursor="SizeNS" Opacity="0" DragDelta="ResizeThumb_DragDelta" Tag="Bottom"/>
            <!-- 左上角 -->
            <Thumb Grid.Row="0" Width="8" Height="8" HorizontalAlignment="Left" VerticalAlignment="Top"
                   Cursor="SizeNWSE" Opacity="0" DragDelta="ResizeThumb_DragDelta" Tag="TopLeft"/>
            <!-- 右上角 -->
            <Thumb Grid.Row="0" Width="8" Height="8" HorizontalAlignment="Right" VerticalAlignment="Top"
                   Cursor="SizeNESW" Opacity="0" DragDelta="ResizeThumb_DragDelta" Tag="TopRight"/>
            <!-- 左下角 -->
            <Thumb Grid.Row="2" Width="8" Height="8" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                   Cursor="SizeNESW" Opacity="0" DragDelta="ResizeThumb_DragDelta" Tag="BottomLeft"/>
            <!-- 右下角 -->
            <Thumb Grid.Row="2" Width="8" Height="8" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                   Cursor="SizeNWSE" Opacity="0" DragDelta="ResizeThumb_DragDelta" Tag="BottomRight"/>
        </Grid>
    </Border>
</Window>
