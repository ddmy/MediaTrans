<Window x:Class="MediaTrans.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MediaTrans.ViewModels"
        Title="{Binding Title}" Height="600" Width="900"
        MinHeight="400" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        Icon="/Assets/app.ico">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <!-- 外层边框提供阴影和圆角 -->
    <Border Background="{DynamicResource BgDarkBrush}" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1"
            Margin="5">
        <Grid>
            <Grid.RowDefinitions>
                <!-- 标题栏 -->
                <RowDefinition Height="32"/>
                <!-- 内容区 -->
                <RowDefinition Height="*"/>
                <!-- 状态栏 -->
                <RowDefinition Height="24"/>
            </Grid.RowDefinitions>

            <!-- 自定义标题栏 -->
            <Grid Grid.Row="0" Background="{DynamicResource BgLightBrush}" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 应用图标和标题 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                    <Image Source="/Assets/app.ico" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="{Binding Title}" Foreground="{DynamicResource FgSecondaryBrush}" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 窗口控制按钮 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <!-- 最小化按钮 -->
                    <Button x:Name="BtnMinimize" Click="BtnMinimize_Click"
                            Style="{StaticResource WindowControlButton}"
                            ToolTip="最小化">
                        <Path Data="M4,8 L12,8" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1" Width="16" Height="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                    <!-- 最大化/还原按钮 -->
                    <Button x:Name="BtnMaximize" Click="BtnMaximize_Click"
                            Style="{StaticResource WindowControlButton}"
                            ToolTip="最大化">
                        <Path Data="M3,3 L13,3 L13,13 L3,13 Z" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1" Fill="Transparent" Width="16" Height="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                    <!-- 关闭按钮 -->
                    <Button x:Name="BtnClose" Click="BtnClose_Click"
                            Style="{StaticResource WindowCloseButton}"
                            ToolTip="关闭">
                        <Path Data="M4,4 L12,12 M12,4 L4,12" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1" Width="16" Height="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- 主内容区 -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <!-- 激活提示横幅（未激活时显示） -->
                    <RowDefinition Height="Auto"/>
                    <!-- 工具栏 -->
                    <RowDefinition Height="36"/>
                    <!-- 左侧文件列表 + 中央预览/编辑区 -->
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 激活提示横幅 -->
                <Border Grid.Row="0" Background="#FFE05050" Padding="6,4"
                        Visibility="{Binding IsLicensed, Converter={StaticResource BoolToVisibilityInverse}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="免费版：导出≤60秒 | 视频含水印 | 禁用FLAC/WAV — 激活专业版解锁全部功能" 
                                   Foreground="White" FontSize="12" VerticalAlignment="Center" Margin="8,0"/>
                        <Button Grid.Column="1" Content="立即激活" 
                                Style="{StaticResource DarkButton}"
                                Command="{Binding OpenLicenseCommand}"
                                Padding="10,2" Margin="0,0,4,0" FontSize="11"/>
                    </Grid>
                </Border>

                <!-- 顶部工具栏 -->
                <Border Grid.Row="1" Background="{DynamicResource BgMediumBrush}"
                        BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                        <Button Content="导入文件" Style="{StaticResource DarkButton}" 
                                Command="{Binding ImportFilesCommand}"
                                Padding="10,3" Margin="0,0,4,0" FontSize="12"/>
                        <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" 
                                   Margin="0,4" Background="{DynamicResource BorderDefaultBrush}"/>
                        <Button Content="许可证" Style="{StaticResource DarkButton}" 
                                Command="{Binding OpenLicenseCommand}"
                                Padding="10,3" Margin="4,0,0,0" FontSize="12" ToolTip="许可证管理"/>
                        <Button Content="ℹ 关于" Style="{StaticResource DarkButton}" 
                                Command="{Binding OpenAboutCommand}"
                                Padding="10,3" Margin="4,0,0,0" FontSize="12" ToolTip="关于我们"/>
                    </StackPanel>
                </Border>

                <!-- 左侧文件列表 + 中央预览区 -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <!-- 左侧文件列表面板 -->
                        <ColumnDefinition Width="260" MinWidth="180" MaxWidth="500"/>
                        <!-- GridSplitter -->
                        <ColumnDefinition Width="4"/>
                        <!-- 中央预览/编辑区 -->
                        <ColumnDefinition Width="*" MinWidth="300"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左侧文件列表面板 -->
                    <Border Grid.Column="0" Background="{DynamicResource BgDarkBrush}"
                            BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,0,1,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <!-- 面板标题 -->
                            <Border Grid.Row="0" Background="{DynamicResource BgLightBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Foreground="{DynamicResource FgSecondaryBrush}" 
                                               FontSize="12" VerticalAlignment="Center" Margin="10,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="文件列表"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEditorMode}" Value="True">
                                                        <Setter Property="Text" Value="点击切换裁剪文件"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsSpliceMode}" Value="True">
                                                        <Setter Property="Text" Value="点击文件添加到拼接"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <Button Grid.Column="1" Content="✕" ToolTip="移除选中文件"
                                            Style="{StaticResource WindowControlButton}"
                                            Command="{Binding RemoveFileCommand}"
                                            FontSize="10" Padding="6,2" Margin="0,0,2,0"/>
                                    <Button Grid.Column="2" Content="清空" ToolTip="清空文件列表"
                                            Style="{StaticResource WindowControlButton}"
                                            Command="{Binding ClearFilesCommand}"
                                            FontSize="10" Padding="6,2" Margin="0,0,4,0"/>
                                </Grid>
                            </Border>
                            <!-- 文件列表区域 -->
                            <ListBox x:Name="FileListBox" Grid.Row="1" Style="{StaticResource DarkListBox}" 
                                     BorderThickness="0"
                                     Background="{DynamicResource BgDarkBrush}"
                                     ItemsSource="{Binding Files}"
                                     SelectedItem="{Binding SelectedFile}"
                                     PreviewMouseLeftButtonDown="FileListBox_PreviewMouseLeftButtonDown"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="4,3">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <!-- 文件名 -->
                                            <TextBlock Grid.Row="0" Text="{Binding FileName}" 
                                                       Foreground="{DynamicResource FgPrimaryBrush}" 
                                                       FontSize="12" TextTrimming="CharacterEllipsis"/>
                                            <!-- 元信息摘要 -->
                                            <TextBlock Grid.Row="1" FontSize="11"
                                                       Foreground="{DynamicResource FgSecondaryBrush}" Margin="0,2,0,0">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0}  {1}">
                                                        <Binding Path="DurationText" Mode="OneWay"/>
                                                        <Binding Path="FileSizeText" Mode="OneWay"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <!-- 拼接模式下底部操作按钮 -->
                            <Border Grid.Row="2" Background="{DynamicResource BgLightBrush}" Padding="6,4"
                                    Visibility="{Binding IsSpliceMode, Converter={StaticResource BoolToVisibility}}">
                                <Button Content="➕ 再次添加选中文件"
                                        Style="{StaticResource DarkButton}"
                                        Command="{Binding AddToSpliceCommand}"
                                        FontSize="11" Padding="8,4"
                                        HorizontalAlignment="Stretch"
                                        ToolTip="将当前选中文件再添加一次到拼接列表"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- 可拖拽分隔条 -->
                    <GridSplitter Grid.Column="1" Width="4" 
                                  HorizontalAlignment="Stretch"
                                  Background="{DynamicResource BgHighlightBrush}"
                                  Cursor="SizeWE"/>

                    <!-- 中央预览/编辑区 -->
                    <Border Grid.Column="2" Background="{DynamicResource BgDarkestBrush}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="36"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- 模式选择标签栏 -->
                            <Border Grid.Row="0" Background="{DynamicResource BgLightBrush}"
                                    BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,0,0,1">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                                    <Button Content="🔄 转换" FontSize="12" Margin="0,0,2,0"
                                            Command="{Binding SwitchToConvertCommand}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource TabButton}">
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsEditorMode}" Value="False"/>
                                                            <Condition Binding="{Binding IsSpliceMode}" Value="False"/>
                                                            <Condition Binding="{Binding IsMusicSearchMode}" Value="False"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentPrimaryBrush}"/>
                                                        <Setter Property="Foreground" Value="{StaticResource AccentPrimaryBrush}"/>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="✂ 裁剪" FontSize="12" Margin="0,0,2,0"
                                            Command="{Binding SwitchToEditorCommand}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource TabButton}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEditorMode}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentPrimaryBrush}"/>
                                                        <Setter Property="Foreground" Value="{StaticResource AccentPrimaryBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="🔗 拼接" FontSize="12"
                                            Command="{Binding SwitchToSpliceCommand}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource TabButton}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSpliceMode}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentPrimaryBrush}"/>
                                                        <Setter Property="Foreground" Value="{StaticResource AccentPrimaryBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="🔍 搜索" FontSize="12" Margin="2,0,0,0"
                                            Command="{Binding SwitchToMusicSearchCommand}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource TabButton}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMusicSearchMode}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentPrimaryBrush}"/>
                                                        <Setter Property="Foreground" Value="{StaticResource AccentPrimaryBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </Border>

                            <!-- 转换模式面板 -->
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ScrollViewer.Style>
                                    <Style TargetType="ScrollViewer">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEditorMode}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsSpliceMode}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsMusicSearchMode}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ScrollViewer.Style>
                                <StackPanel Margin="16">

                                    <!-- 未选文件时的占位提示 -->
                                    <TextBlock Text="请导入音视频文件"
                                               Foreground="{DynamicResource FgMutedBrush}" FontSize="14"
                                               HorizontalAlignment="Center" Margin="0,40,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedFile}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!-- 文件信息与设置区（选中文件后可见） -->
                                    <StackPanel>
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedFile}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>

                                        <!-- 文件信息 -->
                                        <TextBlock Text="文件信息" Foreground="{DynamicResource FgPrimaryBrush}"
                                                   FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <TextBlock Foreground="{DynamicResource FgSecondaryBrush}" FontSize="12"
                                                   Margin="0,2,0,0" TextTrimming="CharacterEllipsis">
                                            <Run Text="名称："/>
                                            <Run Text="{Binding SelectedFile.FileName, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock Foreground="{DynamicResource FgSecondaryBrush}" FontSize="12" Margin="0,2,0,0">
                                            <Run Text="时长："/>
                                            <Run Text="{Binding SelectedFile.DurationText, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock Foreground="{DynamicResource FgSecondaryBrush}" FontSize="12" Margin="0,2,0,0">
                                            <Run Text="格式："/>
                                            <Run Text="{Binding SelectedFile.Format, Mode=OneWay}"/>
                                        </TextBlock>

                                        <!-- 转换设置 -->
                                        <TextBlock Text="转换设置" Foreground="{DynamicResource FgPrimaryBrush}"
                                                   FontSize="13" FontWeight="SemiBold" Margin="0,16,0,8"/>

                                        <!-- 媒体类型切换 -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <Button Content="🎬 视频" FontSize="12" Padding="12,4" Margin="0,0,4,0"
                                                    Command="{Binding SwitchToVideoToolCommand}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource DarkButton}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsAudioToolMode}" Value="False">
                                                                <Setter Property="BorderBrush" Value="{StaticResource AccentPrimaryBrush}"/>
                                                                <Setter Property="Foreground" Value="{StaticResource AccentPrimaryBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <Button Content="🎵 音频" FontSize="12" Padding="12,4"
                                                    Command="{Binding SwitchToAudioToolCommand}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource DarkButton}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsAudioToolMode}" Value="True">
                                                                <Setter Property="BorderBrush" Value="{StaticResource AccentPrimaryBrush}"/>
                                                                <Setter Property="Foreground" Value="{StaticResource AccentPrimaryBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </StackPanel>

                                        <!-- 输出格式 -->
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="输出格式："
                                                       Foreground="{DynamicResource FgSecondaryBrush}"
                                                       FontSize="12" VerticalAlignment="Center"/>
                                            <ComboBox Grid.Column="1"
                                                      Style="{StaticResource DarkComboBox}"
                                                      ItemsSource="{Binding FilteredOutputFormats}"
                                                      SelectedItem="{Binding SettingsVm.SelectedFormat}"
                                                      FontSize="12"/>
                                        </Grid>

                                        <!-- 预设 -->
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="预设："
                                                       Foreground="{DynamicResource FgSecondaryBrush}"
                                                       FontSize="12" VerticalAlignment="Center"/>
                                            <ComboBox Grid.Column="1"
                                                      Style="{StaticResource DarkComboBox}"
                                                      ItemsSource="{Binding SettingsVm.FilteredPresets}"
                                                      SelectedItem="{Binding SettingsVm.SelectedPreset}"
                                                      DisplayMemberPath="Name"
                                                      FontSize="12"/>
                                        </Grid>

                                        <!-- 操作按钮区（视频模式） -->
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0"
                                                    Visibility="{Binding IsAudioToolMode, Converter={StaticResource BoolToVisibilityInverse}}">
                                            <Button Content="▶ 开始转换" Style="{StaticResource AccentButton}"
                                                    Command="{Binding StartConversionCommand}"
                                                    Padding="12,5" Margin="0,0,8,0" FontSize="12"/>
                                            <Button Content="提取音频流" Style="{StaticResource DarkButton}"
                                                    Command="{Binding ExtractAudioCommand}"
                                                    Padding="10,5" FontSize="12" ToolTip="从视频中提取音频"/>
                                        </StackPanel>

                                        <!-- 操作按钮区（音频模式） -->
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0"
                                                    Visibility="{Binding IsAudioToolMode, Converter={StaticResource BoolToVisibility}}">
                                            <Button Content="▶ 开始转换" Style="{StaticResource AccentButton}"
                                                    Command="{Binding StartConversionCommand}"
                                                    Padding="12,5" Margin="0,0,8,0" FontSize="12"/>
                                            <Button Content="提取视频流" Style="{StaticResource DarkButton}"
                                                    Command="{Binding ExtractVideoCommand}"
                                                    Padding="10,5" FontSize="12" ToolTip="从视频中去除音频，仅保留视频"/>
                                        </StackPanel>

                                        <!-- 校验消息 -->
                                        <TextBlock Text="{Binding SettingsVm.ValidationMessage}"
                                                   Foreground="#FFE05050" FontSize="11" Margin="0,6,0,0"
                                                   TextWrapping="Wrap"/>

                                        <!-- 进度区（转换中时可见） -->
                                        <Border Margin="0,14,0,0" Padding="12"
                                                Background="{DynamicResource BgMediumBrush}"
                                                BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1"
                                                Visibility="{Binding ProgressVm.ShowProgressPanel, Converter={StaticResource BoolToVisibility}}">
                                            <StackPanel>
                                                <Grid Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding ProgressVm.StatusHeaderText}"
                                                               Foreground="{DynamicResource FgSecondaryBrush}" FontSize="12" VerticalAlignment="Center"/>
                                                    <Button Grid.Column="1" Content="{Binding ProgressVm.StopButtonText}"
                                                            Style="{StaticResource DangerButton}"
                                                            Command="{Binding StopConversionCommand}"
                                                            Padding="8,3" FontSize="11"/>
                                                </Grid>
                                                <ProgressBar Style="{StaticResource DarkProgressBar}"
                                                             Minimum="0" Maximum="100"
                                                             Value="{Binding ProgressVm.ProgressPercentage, Mode=OneWay}"
                                                             Height="8"/>
                                                <Grid Margin="0,6,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding ProgressVm.ProgressText, Mode=OneWay}"
                                                               Foreground="{DynamicResource FgSecondaryBrush}" FontSize="12"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding ProgressVm.RemainingTimeText, Mode=OneWay}"
                                                               Foreground="{DynamicResource FgMutedBrush}" FontSize="11"/>
                                                </Grid>
                                                <TextBlock Text="日志" Foreground="{DynamicResource FgSecondaryBrush}"
                                                           FontSize="11" Margin="0,8,0,4"/>
                                                <ListBox Style="{StaticResource DarkListBox}"
                                                         ItemsSource="{Binding ProgressVm.LogEntries}"
                                                         MaxHeight="80" FontSize="10"
                                                         BorderThickness="0"
                                                         ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- 编辑器模式面板 -->
                            <Grid Grid.Row="1"
                                  Visibility="{Binding IsEditorMode, Converter={StaticResource BoolToVisibility}}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel Margin="12">

                                        <!-- 未选文件提示 -->
                                        <TextBlock Text="请先在左侧文件列表中选择音视频文件，然后进行裁剪"
                                                   Foreground="{DynamicResource FgMutedBrush}" FontSize="12"
                                                   TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,30,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding EditorVm.HasFile}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <!-- 编辑器内容（有文件时显示） -->
                                        <StackPanel>
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding EditorVm.HasFile}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>

                                            <!-- 文件信息栏 -->
                                            <Border Background="{DynamicResource BgMediumBrush}"
                                                    BorderBrush="{DynamicResource BorderDefaultBrush}"
                                                    BorderThickness="0,0,0,1" Padding="8,5" Margin="0,0,0,8">
                                                <TextBlock Text="{Binding EditorVm.FileInfoText}"
                                                           Foreground="{DynamicResource FgSecondaryBrush}"
                                                           FontSize="11" TextTrimming="CharacterEllipsis"/>
                                            </Border>

                                            <!-- ===== 波形显示区域 ===== -->
                                            <TextBlock Text="波形预览（点击或拖动可定位进度）" Foreground="{DynamicResource FgPrimaryBrush}"
                                                       FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                            <Border x:Name="WaveformBorder" Height="130"
                                                    Background="{DynamicResource BgDarkestBrush}"
                                                    BorderBrush="{DynamicResource BorderDefaultBrush}"
                                                    BorderThickness="1" Margin="0,0,0,4" ClipToBounds="True"
                                                    MouseLeftButtonDown="WaveformBorder_MouseLeftButtonDown"
                                                    MouseMove="WaveformBorder_MouseMove"
                                                    MouseLeftButtonUp="WaveformBorder_MouseLeftButtonUp"
                                                    Cursor="Hand">
                                                <!-- 波形图叠加层 -->
                                                <Grid x:Name="WaveformGrid">
                                                    <!-- 无波形时的提示 -->
                                                    <TextBlock Text="加载波形中..."
                                                               Foreground="{DynamicResource FgMutedBrush}"
                                                               FontSize="12" HorizontalAlignment="Center"
                                                               VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding EditorVm.WaveformImage}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <!-- 波形图像 -->
                                                    <Image Source="{Binding EditorVm.WaveformImage}"
                                                           Stretch="Fill" SnapsToDevicePixels="True"/>
                                                    <!-- 裁剪选区高亮（蓝色半透明区域） -->
                                                    <Border Opacity="0.25" Background="{DynamicResource AccentPrimaryBrush}"
                                                            HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                                        <Border.Margin>
                                                            <MultiBinding Converter="{StaticResource TrimRegionMargin}">
                                                                <Binding Path="EditorVm.TrimStartPercent" Mode="OneWay"/>
                                                                <Binding Path="EditorVm.TrimEndPercent" Mode="OneWay"/>
                                                                <Binding RelativeSource="{RelativeSource AncestorType=Grid}" Path="ActualWidth"/>
                                                            </MultiBinding>
                                                        </Border.Margin>
                                                    </Border>
                                                    <!-- 裁剪起始标记线（绿色） -->
                                                    <Border Width="2" Background="#FF50C878"
                                                            HorizontalAlignment="Left" VerticalAlignment="Stretch">
                                                        <Border.Margin>
                                                            <MultiBinding Converter="{StaticResource ProgressToLeftMargin}">
                                                                <Binding Path="EditorVm.TrimStartPercent" Mode="OneWay"/>
                                                                <Binding RelativeSource="{RelativeSource AncestorType=Grid}" Path="ActualWidth"/>
                                                            </MultiBinding>
                                                        </Border.Margin>
                                                    </Border>
                                                    <!-- 裁剪结束标记线（红色） -->
                                                    <Border Width="2" Background="#FFFF6060"
                                                            HorizontalAlignment="Left" VerticalAlignment="Stretch">
                                                        <Border.Margin>
                                                            <MultiBinding Converter="{StaticResource ProgressToLeftMargin}">
                                                                <Binding Path="EditorVm.TrimEndPercent" Mode="OneWay"/>
                                                                <Binding RelativeSource="{RelativeSource AncestorType=Grid}" Path="ActualWidth"/>
                                                            </MultiBinding>
                                                        </Border.Margin>
                                                    </Border>
                                                    <!-- 播放头竖线（蓝白色，粗1px） -->
                                                    <Border Width="2" Background="White" Opacity="0.9"
                                                            HorizontalAlignment="Left" VerticalAlignment="Stretch">
                                                        <Border.Margin>
                                                            <MultiBinding Converter="{StaticResource ProgressToLeftMargin}">
                                                                <Binding Path="EditorVm.PlaybackProgressPercent" Mode="OneWay"/>
                                                                <Binding RelativeSource="{RelativeSource AncestorType=Grid}" Path="ActualWidth"/>
                                                            </MultiBinding>
                                                        </Border.Margin>
                                                    </Border>
                                                    <!-- 拖拽时间提示气泡 -->
                                                    <Border x:Name="DragTooltip" Visibility="Collapsed"
                                                            Background="#CC000000" CornerRadius="3" Padding="4,2"
                                                            HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                                            Margin="0,0,0,4" IsHitTestVisible="False">
                                                        <TextBlock x:Name="DragTooltipText" Foreground="White"
                                                                   FontSize="10" FontFamily="Consolas"/>
                                                    </Border>
                                                </Grid>
                                            </Border>

                                            <!-- 播放控制行：时间 + 播放/停止 -->
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding EditorVm.CurrentTimeText}"
                                                           Foreground="{DynamicResource FgSecondaryBrush}"
                                                           FontFamily="Consolas, Courier New"
                                                           FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                    <Button Content="{Binding EditorVm.PlayPauseLabel}"
                                                            Style="{StaticResource AccentButton}"
                                                            Command="{Binding EditorVm.PlayPauseCommand}"
                                                            Padding="14,4" Margin="0,0,6,0" FontSize="12"
                                                            ToolTip="播放/暂停（点击波形可定位）"/>
                                                    <Button Content="⏹ 停止"
                                                            Style="{StaticResource DarkButton}"
                                                            Command="{Binding EditorVm.StopCommand}"
                                                            Padding="10,4" Margin="0,0,6,0" FontSize="12"/>
                                                    <Button Content="▶ 播放选区"
                                                            Style="{StaticResource DarkButton}"
                                                            Command="{Binding EditorVm.PlaySelectionCommand}"
                                                            Padding="10,4" FontSize="12"
                                                            ToolTip="播放裁剪选区范围，到达终点自动停止"/>
                                                </StackPanel>
                                            </Grid>

                                            <!-- ===== 裁剪设置 ===== -->
                                            <Border Background="{DynamicResource BgMediumBrush}"
                                                    BorderBrush="{DynamicResource BorderDefaultBrush}"
                                                    BorderThickness="1" CornerRadius="4"
                                                    Padding="10,8" Margin="0,0,0,8">
                                                <StackPanel>
                                                    <TextBlock Text="✂ 裁剪设置"
                                                               Foreground="{DynamicResource FgPrimaryBrush}"
                                                               FontSize="12" FontWeight="SemiBold"
                                                               Margin="0,0,0,8"/>

                                                    <!-- 起始时间 -->
                                                    <Grid Margin="0,0,0,6">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="60"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="起点："
                                                                   Foreground="{DynamicResource FgSecondaryBrush}"
                                                                   FontSize="12" VerticalAlignment="Center"/>
                                                        <TextBox Grid.Column="1"
                                                                 Style="{StaticResource TimeInputBox}"
                                                                 Text="{Binding EditorVm.TrimStartText, UpdateSourceTrigger=LostFocus}"
                                                                 ToolTip="格式：HH:MM:SS.mmm"/>
                                                        <Button Grid.Column="2" Content="标记入点"
                                                                Style="{StaticResource DarkButton}"
                                                                Command="{Binding EditorVm.MarkInCommand}"
                                                                Padding="8,3" Margin="4,0,0,0" FontSize="11"
                                                                ToolTip="将当前播放位置设为起点"/>
                                                    </Grid>

                                                    <!-- 结束时间 -->
                                                    <Grid Margin="0,0,0,8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="60"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="终点："
                                                                   Foreground="{DynamicResource FgSecondaryBrush}"
                                                                   FontSize="12" VerticalAlignment="Center"/>
                                                        <TextBox Grid.Column="1"
                                                                 Style="{StaticResource TimeInputBox}"
                                                                 Text="{Binding EditorVm.TrimEndText, UpdateSourceTrigger=LostFocus}"
                                                                 ToolTip="格式：HH:MM:SS.mmm"/>
                                                        <Button Grid.Column="2" Content="标记出点"
                                                                Style="{StaticResource DarkButton}"
                                                                Command="{Binding EditorVm.MarkOutCommand}"
                                                                Padding="8,3" Margin="4,0,0,0" FontSize="11"
                                                                ToolTip="将当前播放位置设为终点"/>
                                                    </Grid>

                                                    <!-- 快捷选择按钮 -->
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                        <Button Content="全选"
                                                                Style="{StaticResource DarkButton}"
                                                                Command="{Binding EditorVm.SelectAllCommand}"
                                                                Padding="8,3" Margin="0,0,6,0" FontSize="11"/>
                                                    </StackPanel>

                                                    <!-- 导出格式和按钮 -->
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="60"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="格式："
                                                                   Foreground="{DynamicResource FgSecondaryBrush}"
                                                                   FontSize="12" VerticalAlignment="Center"/>
                                                        <ComboBox Grid.Column="1"
                                                                  Style="{StaticResource DarkComboBox}"
                                                                  ItemsSource="{Binding EditorVm.ExportFormats}"
                                                                  SelectedItem="{Binding EditorVm.SelectedExportFormat}"
                                                                  FontSize="12"/>
                                                        <Button Grid.Column="2" Content="🎬 导出裁剪"
                                                                Style="{StaticResource AccentButton}"
                                                                Command="{Binding EditorVm.TrimExportCommand}"
                                                                Padding="12,5" Margin="6,0,0,0" FontSize="12"/>
                                                        <Button Grid.Column="3" Content="停止"
                                                                Style="{StaticResource DangerButton}"
                                                                Command="{Binding EditorVm.StopExportCommand}"
                                                                Padding="8,5" Margin="4,0,0,0" FontSize="12"
                                                                Visibility="{Binding EditorVm.IsExporting, Converter={StaticResource BoolToVisibility}}"/>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>

                                            <!-- 导出状态 -->
                                            <TextBlock Text="{Binding EditorVm.StatusText}"
                                                       Foreground="{DynamicResource FgMutedBrush}"
                                                       FontSize="11" TextWrapping="Wrap"
                                                       Margin="0,0,0,8"/>

                                            <!-- ===== 增益调节 ===== -->
                                            <Border Background="{DynamicResource BgMediumBrush}"
                                                    BorderBrush="{DynamicResource BorderDefaultBrush}"
                                                    BorderThickness="1" CornerRadius="4"
                                                    Padding="10,8" Margin="0,0,0,8">
                                                <StackPanel>
                                                    <Grid Margin="0,0,0,4">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="🔊 音量增益"
                                                                   Foreground="{DynamicResource FgPrimaryBrush}"
                                                                   FontSize="12" FontWeight="SemiBold"/>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding EditorVm.GainText}"
                                                                   Foreground="{DynamicResource AccentPrimaryBrush}"
                                                                   FontFamily="Consolas, Courier New"
                                                                   FontSize="12"/>
                                                    </Grid>
                                                    <Slider Style="{StaticResource DarkSlider}"
                                                            Minimum="-20" Maximum="20"
                                                            Value="{Binding EditorVm.GainDb}"
                                                            TickFrequency="5"
                                                            ToolTip="{Binding EditorVm.GainText}"/>
                                                    <Grid Margin="0,2,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="-20 dB"
                                                                   Foreground="{DynamicResource FgMutedBrush}"
                                                                   FontSize="10"/>
                                                        <TextBlock Grid.Column="1" Text="0"
                                                                   Foreground="{DynamicResource FgMutedBrush}"
                                                                   FontSize="10" HorizontalAlignment="Center"/>
                                                        <TextBlock Grid.Column="2" Text="+20 dB"
                                                                   Foreground="{DynamicResource FgMutedBrush}"
                                                                   FontSize="10" HorizontalAlignment="Right"/>
                                                    </Grid>
                                                    <TextBlock Text="注：增益在导出时写入文件；播放预览仅支持音量降低（负值）"
                                                               Foreground="{DynamicResource FgMutedBrush}"
                                                               FontSize="10" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>

                                        </StackPanel>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>

                            <!-- 拼接模式面板 -->
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                          Visibility="{Binding IsSpliceMode, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel Margin="16">
                                    <TextBlock Text="🔗 多段拼接"
                                               Foreground="{DynamicResource FgPrimaryBrush}"
                                               FontSize="14" FontWeight="SemiBold"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="将多个音视频文件按顺序拼接为一个文件"
                                               Foreground="{DynamicResource FgMutedBrush}"
                                               FontSize="12" Margin="0,0,0,12"/>

                                    <!-- 拼接文件列表 -->
                                    <Border Background="{DynamicResource BgMediumBrush}"
                                            BorderBrush="{DynamicResource BorderDefaultBrush}"
                                            BorderThickness="1" CornerRadius="4"
                                            Padding="10,8" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="文件列表" Foreground="{DynamicResource FgPrimaryBrush}"
                                                       FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                            <ListBox Style="{StaticResource DarkListBox}"
                                                     ItemsSource="{Binding EditorVm.SpliceFiles}"
                                                     MaxHeight="200" BorderThickness="1"
                                                     Margin="0,0,0,8"
                                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="2,2" CornerRadius="3" Padding="4,2">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="Transparent"/>
                                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                                    <Setter Property="BorderThickness" Value="1"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsVirtualGap}" Value="True">
                                                                            <Setter Property="Background" Value="#33252540"/>
                                                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentPrimaryBrush}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="80"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0"
                                                                           Text="GAP"
                                                                           Margin="0,0,6,0"
                                                                           Padding="4,1"
                                                                           FontSize="10"
                                                                           VerticalAlignment="Center"
                                                                           Visibility="Collapsed"
                                                                           Foreground="White"
                                                                           Background="{DynamicResource AccentPrimaryBrush}">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsVirtualGap}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding FileName}"
                                                                           Foreground="{DynamicResource FgPrimaryBrush}"
                                                                           FontSize="12"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           VerticalAlignment="Center"/>
                                                                <TextBlock Grid.Column="2"
                                                                           Text="{Binding DurationText}"
                                                                           Foreground="{DynamicResource FgMutedBrush}"
                                                                           FontSize="11"
                                                                           FontFamily="Consolas, Courier New"
                                                                           HorizontalAlignment="Right"
                                                                           VerticalAlignment="Center"
                                                                           Margin="4,0"/>
                                                                <Button Grid.Column="3" Content="↑"
                                                                        Style="{StaticResource DarkButton}"
                                                                        Command="{Binding DataContext.EditorVm.MoveSpliceUpCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}"
                                                                        Padding="4,2" Margin="2,0,0,0"
                                                                        FontSize="10"
                                                                        ToolTip="上移"/>
                                                                <Button Grid.Column="4" Content="↓"
                                                                        Style="{StaticResource DarkButton}"
                                                                        Command="{Binding DataContext.EditorVm.MoveSpliceDownCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}"
                                                                        Padding="4,2" Margin="2,0,0,0"
                                                                        FontSize="10"
                                                                        ToolTip="下移"/>
                                                                <Button Grid.Column="5" Content="✕"
                                                                        Style="{StaticResource DarkButton}"
                                                                        Command="{Binding DataContext.EditorVm.RemoveSpliceFileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}"
                                                                        Padding="4,2" Margin="2,0,0,0"
                                                                        FontSize="10"
                                                                        ToolTip="移除此项"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>

                                            <!-- 操作按钮 -->
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="+ 添加文件"
                                                        Style="{StaticResource DarkButton}"
                                                        Command="{Binding EditorVm.AddSpliceFileCommand}"
                                                        Padding="10,4" Margin="0,0,6,0" FontSize="12"/>
                                                <Button Content="+ 插入静音黑屏片段"
                                                    Style="{StaticResource DarkButton}"
                                                    Command="{Binding EditorVm.AddSilenceBlackSegmentCommand}"
                                                    Padding="10,4" Margin="0,0,6,0" FontSize="12"
                                                    ToolTip="插入可排序的黑屏+静音片段"/>
                                                <Button Content="🔗 拼接导出"
                                                        Style="{StaticResource AccentButton}"
                                                        Command="{Binding EditorVm.SpliceExportCommand}"
                                                        Padding="10,4" FontSize="12"
                                                    ToolTip="至少需要 2 个片段且包含 1 个真实文件"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- 导出状态 -->
                                    <TextBlock Text="{Binding EditorVm.StatusText}"
                                               Foreground="{DynamicResource FgMutedBrush}"
                                               FontSize="11" TextWrapping="Wrap"/>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- 音乐搜索模式面板 -->
                            <Grid Grid.Row="1"
                                  Visibility="{Binding IsMusicSearchMode, Converter={StaticResource BoolToVisibility}}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- 搜索栏 -->
                                <Border Grid.Row="0" Padding="12,8"
                                        Background="{DynamicResource BgMediumBrush}"
                                        BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                                 Style="{StaticResource TimeInputBox}"
                                                 Text="{Binding MusicSearchVm.SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="13" Padding="6,4"
                                                 ToolTip="输入歌名、歌手或关键词，回车搜索"
                                                 KeyDown="MusicSearchBox_KeyDown"/>
                                        <Button Grid.Column="1" Content="搜索"
                                                Style="{StaticResource AccentButton}"
                                                Command="{Binding MusicSearchVm.SearchCommand}"
                                                Padding="14,4" Margin="6,0,0,0" FontSize="12"/>
                                    </Grid>
                                </Border>

                                <!-- 平台筛选栏 -->
                                <Border Grid.Row="1" Padding="12,4"
                                        Background="{DynamicResource BgDarkBrush}">
                                    <ItemsControl ItemsSource="{Binding MusicSearchVm.PlatformFilters}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <ToggleButton IsChecked="{Binding IsChecked}"
                                                              Content="{Binding DisplayText}"
                                                              Margin="0,0,6,0" Padding="6,2"
                                                              FontSize="11" Cursor="Hand">
                                                    <ToggleButton.Style>
                                                        <Style TargetType="ToggleButton">
                                                            <Setter Property="Background" Value="Transparent"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource FgMutedBrush}"/>
                                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderDefaultBrush}"/>
                                                            <Setter Property="BorderThickness" Value="1"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="ToggleButton">
                                                                        <Border Background="{TemplateBinding Background}"
                                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                                CornerRadius="3"
                                                                                Padding="{TemplateBinding Padding}">
                                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                                              VerticalAlignment="Center"/>
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Style.Triggers>
                                                                <Trigger Property="IsChecked" Value="True">
                                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                                    <Setter Property="Foreground" Value="White"/>
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                                </Trigger>
                                                                <Trigger Property="IsChecked" Value="False">
                                                                    <Setter Property="Background" Value="Transparent"/>
                                                                    <Setter Property="Foreground" Value="{DynamicResource FgMutedBrush}"/>
                                                                </Trigger>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Opacity" Value="0.85"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ToggleButton.Style>
                                                </ToggleButton>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>

                                <!-- 搜索结果列表 -->
                                <ListBox Grid.Row="2" Style="{StaticResource DarkListBox}"
                                         BorderThickness="0"
                                         Background="{DynamicResource BgDarkestBrush}"
                                         ItemsSource="{Binding MusicSearchVm.Results}"
                                         SelectedItem="{Binding MusicSearchVm.SelectedResult}"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         MouseDoubleClick="MusicResultList_MouseDoubleClick"
                                         x:Name="MusicResultListBox"
                                         Tag="{Binding}">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                            <Setter Property="ContextMenu">
                                                <Setter.Value>
                                                    <ContextMenu Style="{StaticResource DarkContextMenu}"
                                                                 DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                                        <MenuItem Header="▶ 试听" Style="{StaticResource DarkMenuItem}"
                                                                  Command="{Binding MusicSearchVm.PlayItemCommand}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        <Separator Style="{StaticResource DarkMenuSeparator}"/>
                                                        <MenuItem Header="⬇ 下载" Style="{StaticResource DarkMenuItem}"
                                                                  Command="{Binding MusicSearchVm.DownloadItemCommand}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                    </ContextMenu>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="8,4">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <!-- 歌名 -->
                                                <TextBlock Grid.Row="0"
                                                           Text="{Binding SongName}"
                                                           Foreground="{DynamicResource FgPrimaryBrush}"
                                                           FontSize="13" TextTrimming="CharacterEllipsis"/>
                                                <!-- 歌手 + 平台选择 + 时长（同一行） -->
                                                <DockPanel Grid.Row="1" Margin="0,2,0,0">
                                                    <!-- 时长（右侧） -->
                                                    <TextBlock DockPanel.Dock="Right"
                                                               Text="{Binding DurationText}"
                                                               Foreground="{DynamicResource FgSecondaryBrush}"
                                                               FontSize="11" FontFamily="Consolas, Courier New"
                                                               VerticalAlignment="Center"
                                                               Margin="8,0,0,0"/>
                                                    <!-- 歌手 + 平台（左侧） -->
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock FontSize="11"
                                                                   Foreground="{DynamicResource FgSecondaryBrush}">
                                                            <Run Text="{Binding Artist, Mode=OneWay}"/>
                                                            <Run Text=" · "/>
                                                        </TextBlock>
                                                        <!-- 多源：下拉切换平台 -->
                                                        <ComboBox ItemsSource="{Binding Sources}"
                                                                  SelectedItem="{Binding SelectedSource}"
                                                                  DisplayMemberPath="PlatformName"
                                                                  FontSize="11" Padding="2,0"
                                                                  MinWidth="70" MaxWidth="120"
                                                                  VerticalAlignment="Center"
                                                                  Style="{StaticResource DarkComboBox}"
                                                                  Visibility="{Binding HasMultipleSources, Converter={StaticResource BoolToVisibility}}"/>
                                                        <!-- 单源：纯文本 -->
                                                        <TextBlock FontSize="11"
                                                                   Foreground="{DynamicResource FgSecondaryBrush}"
                                                                   Text="{Binding AvailablePlatformsText}"
                                                                   VerticalAlignment="Center"
                                                                   Visibility="{Binding HasMultipleSources, Converter={StaticResource BoolToVisibilityInverse}}"/>
                                                    </StackPanel>
                                                </DockPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <!-- 底部操作栏 -->
                                <Border Grid.Row="3" Padding="12,8"
                                        Background="{DynamicResource BgMediumBrush}"
                                        BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,1,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- 播放按钮 -->
                                        <Button Grid.Column="0" Content="▶ 试听"
                                                Style="{StaticResource AccentButton}"
                                                Command="{Binding MusicSearchVm.PlayCommand}"
                                                Padding="10,4" Margin="0,0,4,0" FontSize="12"/>
                                        <Button Grid.Column="1" Content="⏹ 停止"
                                                Style="{StaticResource DarkButton}"
                                                Command="{Binding MusicSearchVm.StopPlayCommand}"
                                                Padding="8,4" Margin="0,0,4,0" FontSize="12"
                                                Visibility="{Binding MusicSearchVm.IsPlaying, Converter={StaticResource BoolToVisibility}}"/>
                                        <!-- 播放进度 -->
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding MusicSearchVm.PlaybackPositionText}"
                                                   Foreground="{DynamicResource FgSecondaryBrush}"
                                                   FontSize="11" FontFamily="Consolas, Courier New"
                                                   VerticalAlignment="Center" Margin="0,0,4,0"
                                                   Visibility="{Binding MusicSearchVm.IsPlaying, Converter={StaticResource BoolToVisibility}}"/>
                                        <ProgressBar Grid.Column="3" Width="80" Height="8" Margin="0,0,8,0"
                                                     Minimum="0" Maximum="100"
                                                     Value="{Binding MusicSearchVm.PlaybackProgress, Mode=OneWay}"
                                                     Visibility="{Binding MusicSearchVm.IsPlaying, Converter={StaticResource BoolToVisibility}}"/>
                                        <!-- 下载格式 -->
                                        <ComboBox Grid.Column="4"
                                                  Style="{StaticResource DarkComboBox}"
                                                  ItemsSource="{Binding MusicSearchVm.DownloadFormats}"
                                                  SelectedItem="{Binding MusicSearchVm.SelectedDownloadFormat}"
                                                  FontSize="12" Width="70" Margin="0,0,4,0"/>
                                        <!-- 状态文本 -->
                                        <TextBlock Grid.Column="5"
                                                   Text="{Binding MusicSearchVm.StatusText}"
                                                   Foreground="{DynamicResource FgMutedBrush}"
                                                   FontSize="11" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" Margin="4,0"/>
                                        <!-- 下载进度 -->
                                        <ProgressBar Grid.Column="6" Width="80" Height="12" Margin="4,0"
                                                     Minimum="0" Maximum="100"
                                                     Value="{Binding MusicSearchVm.DownloadProgress, Mode=OneWay}">
                                            <ProgressBar.Style>
                                                <Style TargetType="ProgressBar">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding MusicSearchVm.IsDownloading}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ProgressBar.Style>
                                        </ProgressBar>
                                        <!-- 下载按钮 -->
                                        <Button Grid.Column="7" Content="⬇ 下载"
                                                Style="{StaticResource DarkButton}"
                                                Command="{Binding MusicSearchVm.DownloadCommand}"
                                                Padding="10,4" FontSize="12"/>
                                    </Grid>
                                </Border>
                            </Grid>

                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- 状态栏 -->
            <Border Grid.Row="2" Background="{DynamicResource BgMediumBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding StatusText}" 
                               Foreground="{DynamicResource FgMutedBrush}" FontSize="11"
                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                    <!-- 导出进度条 -->
                    <ProgressBar Grid.Column="1" Width="200" Height="14" Margin="6,0,10,0"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding EditorVm.ExportProgress, Mode=OneWay}">
                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding EditorVm.IsExporting}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>
                </Grid>
            </Border>

            <!-- 缩放把手（8个方向） -->
            <!-- 左边缘 -->
            <Thumb Grid.Row="0" Grid.RowSpan="3" Width="5" HorizontalAlignment="Left" 
                   Cursor="SizeWE" Opacity="0" DragDelta="ResizeThumb_DragDelta" Tag="Left"/>
            <!-- 右边缘 -->
            <Thumb Grid.Row="0" Grid.RowSpan="3" Width="5" HorizontalAlignment="Right" 
                   Cursor="SizeWE" Opacity="0" DragDelta="ResizeThumb_DragDelta" Tag="Right"/>
            <!-- 上边缘 -->
            <Thumb Grid.Row="0" Height="5" VerticalAlignment="Top" 
                   Cursor="SizeNS" Opacity="0" DragDelta="ResizeThumb_DragDelta" Tag="Top"/>
            <!-- 下边缘 -->
            <Thumb Grid.Row="2" Height="5" VerticalAlignment="Bottom" 
                   Cursor="SizeNS" Opacity="0" DragDelta="ResizeThumb_DragDelta" Tag="Bottom"/>
            <!-- 左上角 -->
            <Thumb Grid.Row="0" Width="8" Height="8" HorizontalAlignment="Left" VerticalAlignment="Top"
                   Cursor="SizeNWSE" Opacity="0" DragDelta="ResizeThumb_DragDelta" Tag="TopLeft"/>
            <!-- 右上角 -->
            <Thumb Grid.Row="0" Width="8" Height="8" HorizontalAlignment="Right" VerticalAlignment="Top"
                   Cursor="SizeNESW" Opacity="0" DragDelta="ResizeThumb_DragDelta" Tag="TopRight"/>
            <!-- 左下角 -->
            <Thumb Grid.Row="2" Width="8" Height="8" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                   Cursor="SizeNESW" Opacity="0" DragDelta="ResizeThumb_DragDelta" Tag="BottomLeft"/>
            <!-- 右下角 -->
            <Thumb Grid.Row="2" Width="8" Height="8" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                   Cursor="SizeNWSE" Opacity="0" DragDelta="ResizeThumb_DragDelta" Tag="BottomRight"/>
        </Grid>
    </Border>
</Window>
