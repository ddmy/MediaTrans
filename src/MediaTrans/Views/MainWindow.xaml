<Window x:Class="MediaTrans.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MediaTrans.ViewModels"
        Title="{Binding Title}" Height="600" Width="900"
        MinHeight="400" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <!-- 外层边框提供阴影和圆角 -->
    <Border Background="{DynamicResource BgDarkBrush}" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1"
            Margin="5">
        <Grid>
            <Grid.RowDefinitions>
                <!-- 标题栏 -->
                <RowDefinition Height="32"/>
                <!-- 内容区 -->
                <RowDefinition Height="*"/>
                <!-- 状态栏 -->
                <RowDefinition Height="24"/>
            </Grid.RowDefinitions>

            <!-- 自定义标题栏 -->
            <Grid Grid.Row="0" Background="{DynamicResource BgLightBrush}" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 应用图标和标题 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                    <TextBlock Text="🎬" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding Title}" Foreground="{DynamicResource FgSecondaryBrush}" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 窗口控制按钮 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <!-- 最小化按钮 -->
                    <Button x:Name="BtnMinimize" Click="BtnMinimize_Click"
                            Style="{StaticResource WindowControlButton}"
                            FontFamily="Segoe MDL2 Assets" Content="&#xE921;"
                            ToolTip="最小化"/>
                    <!-- 最大化/还原按钮 -->
                    <Button x:Name="BtnMaximize" Click="BtnMaximize_Click"
                            Style="{StaticResource WindowControlButton}"
                            FontFamily="Segoe MDL2 Assets" Content="&#xE922;"
                            ToolTip="最大化"/>
                    <!-- 关闭按钮 -->
                    <Button x:Name="BtnClose" Click="BtnClose_Click"
                            Style="{StaticResource WindowCloseButton}"
                            FontFamily="Segoe MDL2 Assets" Content="&#xE8BB;"
                            ToolTip="关闭"/>
                </StackPanel>
            </Grid>

            <!-- 主内容区 -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <!-- 工具栏 -->
                    <RowDefinition Height="36"/>
                    <!-- 左侧文件列表 + 中央预览/编辑区 -->
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 顶部工具栏 -->
                <Border Grid.Row="0" Background="{DynamicResource BgMediumBrush}"
                        BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                        <Button Content="导入文件" Style="{StaticResource DarkButton}" 
                                Command="{Binding ImportFilesCommand}"
                                Padding="10,3" Margin="0,0,4,0" FontSize="12"/>
                        <Button Content="开始转换" Style="{StaticResource AccentButton}" 
                                Padding="10,3" Margin="0,0,4,0" FontSize="12"/>
                        <Button Content="停止" Style="{StaticResource DarkButton}" 
                                Padding="10,3" Margin="0,0,16,0" FontSize="12"/>
                        <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" 
                                   Margin="0,4" Background="{DynamicResource BorderDefaultBrush}"/>
                        <Button Content="设置" Style="{StaticResource DarkButton}" 
                                Padding="10,3" Margin="16,0,0,0" FontSize="12"/>
                    </StackPanel>
                </Border>

                <!-- 左侧文件列表 + 中央预览区 -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <!-- 左侧文件列表面板 -->
                        <ColumnDefinition Width="260" MinWidth="180" MaxWidth="500"/>
                        <!-- GridSplitter -->
                        <ColumnDefinition Width="4"/>
                        <!-- 中央预览/编辑区 -->
                        <ColumnDefinition Width="*" MinWidth="300"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左侧文件列表面板 -->
                    <Border Grid.Column="0" Background="{DynamicResource BgDarkBrush}"
                            BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,0,1,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <!-- 面板标题 -->
                            <Border Grid.Row="0" Background="{DynamicResource BgLightBrush}">
                                <TextBlock Text="文件列表" Foreground="{DynamicResource FgSecondaryBrush}" 
                                           FontSize="12" VerticalAlignment="Center" Margin="10,0"/>
                            </Border>
                            <!-- 文件列表区域 -->
                            <ListBox Grid.Row="1" Style="{StaticResource DarkListBox}" 
                                     BorderThickness="0"
                                     Background="{DynamicResource BgDarkBrush}"
                                     ItemsSource="{Binding Files}"
                                     SelectedItem="{Binding SelectedFile}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="4,3">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <!-- 文件名 -->
                                            <TextBlock Grid.Row="0" Text="{Binding FileName}" 
                                                       Foreground="{DynamicResource FgPrimaryBrush}" 
                                                       FontSize="12" TextTrimming="CharacterEllipsis"/>
                                            <!-- 元信息摘要 -->
                                            <TextBlock Grid.Row="1" FontSize="10"
                                                       Foreground="{DynamicResource FgMutedBrush}" Margin="0,2,0,0">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0}  {1}">
                                                        <Binding Path="DurationText"/>
                                                        <Binding Path="FileSizeText"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <!-- 可拖拽分隔条 -->
                    <GridSplitter Grid.Column="1" Width="4" 
                                  HorizontalAlignment="Stretch"
                                  Background="{DynamicResource BgHighlightBrush}"
                                  Cursor="SizeWE"/>

                    <!-- 中央预览/编辑区 -->
                    <Border Grid.Column="2" Background="{DynamicResource BgDarkestBrush}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <!-- 预览区标题 -->
                            <Border Grid.Row="0" Background="{DynamicResource BgLightBrush}">
                                <TextBlock Text="预览 / 编辑" Foreground="{DynamicResource FgSecondaryBrush}" 
                                           FontSize="12" VerticalAlignment="Center" Margin="10,0"/>
                            </Border>
                            <!-- 预览内容区 -->
                            <Grid Grid.Row="1">
                                <TextBlock Text="请导入音视频文件" 
                                           Foreground="{DynamicResource FgMutedBrush}" FontSize="14"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- 状态栏 -->
            <Border Grid.Row="2" Background="{DynamicResource BgMediumBrush}">
                <TextBlock Text="{Binding StatusText}" 
                           Foreground="{DynamicResource FgMutedBrush}" FontSize="11"
                           VerticalAlignment="Center" Margin="10,0,0,0"/>
            </Border>

            <!-- 缩放把手（8个方向） -->
            <!-- 左边缘 -->
            <Thumb Grid.Row="0" Grid.RowSpan="3" Width="5" HorizontalAlignment="Left" 
                   Cursor="SizeWE" Opacity="0" DragDelta="ResizeThumb_DragDelta" Tag="Left"/>
            <!-- 右边缘 -->
            <Thumb Grid.Row="0" Grid.RowSpan="3" Width="5" HorizontalAlignment="Right" 
                   Cursor="SizeWE" Opacity="0" DragDelta="ResizeThumb_DragDelta" Tag="Right"/>
            <!-- 上边缘 -->
            <Thumb Grid.Row="0" Height="5" VerticalAlignment="Top" 
                   Cursor="SizeNS" Opacity="0" DragDelta="ResizeThumb_DragDelta" Tag="Top"/>
            <!-- 下边缘 -->
            <Thumb Grid.Row="2" Height="5" VerticalAlignment="Bottom" 
                   Cursor="SizeNS" Opacity="0" DragDelta="ResizeThumb_DragDelta" Tag="Bottom"/>
            <!-- 左上角 -->
            <Thumb Grid.Row="0" Width="8" Height="8" HorizontalAlignment="Left" VerticalAlignment="Top"
                   Cursor="SizeNWSE" Opacity="0" DragDelta="ResizeThumb_DragDelta" Tag="TopLeft"/>
            <!-- 右上角 -->
            <Thumb Grid.Row="0" Width="8" Height="8" HorizontalAlignment="Right" VerticalAlignment="Top"
                   Cursor="SizeNESW" Opacity="0" DragDelta="ResizeThumb_DragDelta" Tag="TopRight"/>
            <!-- 左下角 -->
            <Thumb Grid.Row="2" Width="8" Height="8" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                   Cursor="SizeNESW" Opacity="0" DragDelta="ResizeThumb_DragDelta" Tag="BottomLeft"/>
            <!-- 右下角 -->
            <Thumb Grid.Row="2" Width="8" Height="8" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                   Cursor="SizeNWSE" Opacity="0" DragDelta="ResizeThumb_DragDelta" Tag="BottomRight"/>
        </Grid>
    </Border>
</Window>
